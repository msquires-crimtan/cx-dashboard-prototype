# Copy this to .env for local development (never commit .env)

# Your Anthropic API key — kept server-side, never sent to the browser
ANTHROPIC_API_KEY=sk-ant-...

# Password your colleague uses to access the chat UI
APP_PASSWORD=choose-a-strong-password

# Secret for signing session cookies — generate with: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
COOKIE_SECRET=generate-a-random-hex-string

# Port (Cloud Run sets this automatically; leave as-is for local)
PORT=8080
